model Empresa {
  id String @id @default(cuid())

  razaoSocial String

  nomeFantasia String?

  cnpj String @unique

  inscricaoEstadual  String?
  inscricaoMunicipal String?

  email    String?
  telefone String?

  cep String?

  logradouro  String?
  numero      String?
  complemento String?

  bairro String?

  municipio       String?
  codigoMunicipio String?

  uf String?

  codigoPais String? @default("1058")
  pais       String? @default("BRASIL")

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação de usuários que possuem acesso à empresa
  usuarios UsuarioEmpresa[]

  clientes          Cliente[]
  produtos          Produto[]
  notasFiscais      NotaFiscal[]
  certificados      CertificadoDigital[]
  naturezasOperacao NaturezaOperacao[]

  sequenciasFiscais  SequenciaFiscal[]
  configuracaoFiscal ConfiguracaoFiscal?
}
