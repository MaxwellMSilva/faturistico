model Produto {
  id String @id @default(cuid())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  tipo TipoItem

  codigo String

  descricao String

  descricaoCompleta String?

  unidade String

  ean String?

  valorUnitario Decimal

  custoUnitario Decimal?

  estoqueAtual Decimal? @default(0)

  ncm  String?
  cest String?

  cfopPadrao String?

  // ICMS

  origemMercadoria Int @default(0)

  cstIcms   String?
  csosnIcms String?

  modalidadeBcIcms Int? @default(3)

  reducaoBcIcms Decimal? @default(0)
  aliquotaIcms  Decimal? @default(0)

  // PIS

  cstPis      String?
  aliquotaPis Decimal? @default(0)

  // COFINS

  cstCofins      String?
  aliquotaCofins Decimal? @default(0)

  // IPI

  cstIpi String?

  codigoEnquadramentoIpi String? @default("999")

  aliquotaIpi Decimal? @default(0)

  // IBS e CBS

  cstIbsCbs String?

  classificacaoTributariaIbsCbs String?

  aliquotaIbsUf  Decimal? @default(0)
  aliquotaIbsMun Decimal? @default(0)
  aliquotaCbs    Decimal? @default(0)

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itensNotaFiscal ItemNotaFiscal[]

  @@unique([empresaId, codigo])
  @@index([empresaId])
}
