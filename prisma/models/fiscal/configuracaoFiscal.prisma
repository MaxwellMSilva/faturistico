model ConfiguracaoFiscal {
  id String @id @default(cuid())

  empresaId String @unique

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  ambiente AmbienteFiscal @default(HOMOLOGACAO)

  regimeTributario RegimeTributario

  serieNfe  Int @default(1)
  serieNfce Int @default(1)

  // Dados usados na NFC-e.
  // Armazenar criptografado, nunca em texto puro.
  cscCriptografado String?
  idCsc            String?

  // Credencial opcional de integração.
  tokenNuvemFiscalCriptografado String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ambiente])
}
