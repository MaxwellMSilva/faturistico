model NotaFiscal {
  id String @id @default(cuid())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  numero Int

  serie Int @default(1)

  status StatusNotaFiscal @default(RASCUNHO)

  valorTotal Decimal @default(0)

  informacoesComplementares String?

  numeroAleatorio String?

  chaveAcesso String?

  protocoloAutorizacao String?

  xmlGerado String?

  xmlAssinado String?

  dataAutorizacao DateTime?

  motivoRejeicao String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens ItemNotaFiscal[]

  naturezaOperacaoId String?
  naturezaOperacao   NaturezaOperacao? @relation(fields: [naturezaOperacaoId], references: [id])

  @@unique([empresaId, numero, serie])
}
