model SequenciaFiscal {
  id String @id @default(cuid())

  empresaId String

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  tipoDocumento TipoDocumentoFiscal

  serie Int @default(1)

  ultimoNumero Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, tipoDocumento, serie])
  @@index([empresaId])
  @@index([empresaId, tipoDocumento])
}
