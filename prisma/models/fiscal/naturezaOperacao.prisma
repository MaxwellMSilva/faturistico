model NaturezaOperacao {
  id String @id @default(cuid())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  descricao     String
  codigoInterno String?

  cfop String

  tipoOperacao    TipoOperacaoFiscal @default(SAIDA)
  destinoOperacao DestinoOperacao    @default(INTERNA)

  finalidadeNfe FinalidadeNfe @default(NORMAL)

  consumidorFinal Boolean @default(false)

  indicadorPresenca       IndicadorPresenca       @default(NAO_SE_APLICA)
  indicadorIeDestinatario IndicadorIeDestinatario @default(CONTRIBUINTE)

  possuiIntermediador Boolean @default(false)

  // Campo legado mantido para compatibilidade com validações existentes.
  // Deve permanecer sincronizado com indicadorIeDestinatario.
  contribuinteIcms Boolean @default(true)

  informacoesComplementaresPadrao String?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notasFiscais NotaFiscal[]

  @@index([empresaId])
  @@index([empresaId, ativo])
  @@index([empresaId, cfop])
}
