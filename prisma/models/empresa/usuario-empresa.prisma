model UsuarioEmpresa {
  id String @id @default(cuid())

  usuarioId String
  empresaId String

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  permissao PermissaoEmpresa @default(VISUALIZADOR)

  ativo Boolean @default(true)

  privilegios UsuarioEmpresaPrivilegio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, empresaId])
  @@index([usuarioId])
  @@index([empresaId])
}
